# ============================================================
# Daily Digest Prompt - .gitignore
# ============================================================

# ── 研究筆記（大型 Markdown/PDF，不納入版控）────────────────
knowledge_base/

# ── 執行時產生的狀態資料（每次執行都會變動）────────────────
logs/
cache/
results/
state/scheduler-state.json
state/todoist-history.json
state/loop-state-*.json
state/stop-alert-*.json
state/api-health.json
state/api-health.json.backup
state/last-audit.json
state/gmail-oauth-state.json
context/digest-memory.json
context/auto-tasks-today.json
context/research-registry.json
context/metrics-daily.json
context/behavior-patterns.json

# ── 影片 / Podcast 媒體輸出（大型二進位，不進版控）──────────
output/
*.mp3
*.mp4
*.wav
*.webm

# ── Remotion 影片工作室（Node.js 工件）─────────────────────
tools/video-studio/node_modules/
tools/video-studio/src/data/remotion-data.json
tools/video-studio/public/audio/
tools/video-studio/public/images/

# ── Bot 任務排程暫存（每次 cron 觸發都會產生新檔）──────────
bot/tasks_md/

# ── 暫存檔（子 Agent / 自動任務 / 工具產生）────────────────
task_prompt.md
task_result.txt
import_note.json
ntfy_temp.json
hooks_alert_temp.json
debug_audio.py
tmp_*
temp_*
*.tmp
*.txt.tmp
{

# ── Gun.js 暫存資料與金鑰 ────────────────────────────────────
bot/radata-*/
bot/radata-*.tmp
bot/data/keypair.json

# ── 根目錄雜項暫存文件 ──────────────────────────────────────
強化方案.md
影片工作流.txt
goose-repo-overview.md
*.plan.md

# ── 備份檔 ──────────────────────────────────────────────────
*.bak

# ── 大型二進位文件（PDF / 影像）────────────────────────────
*.pdf
chatroom-*.png
table_render_*.png

# ── 參考文件（外部複製，非系統核心）────────────────────────
AgentTeams-*.md
ClaudeCodeTeamAgent.*

# ── Windows 誤產生 ──────────────────────────────────────────
nul

# ── 工具快取 ────────────────────────────────────────────────
.ruff_cache/
.pytest_cache/
.playwright-mcp/
htmlcov/

# ── Python ──────────────────────────────────────────────────
__pycache__/
*.pyc
*.pyo
.venv/
.coverage

# ── Node.js（根目錄 / 其他子專案）──────────────────────────
node_modules/
dist/
.next/
.nuxt/

# ── Secrets ─────────────────────────────────────────────────
.env
.env.*
!.env.example
secrets/
credentials.json
token.json
key/
*.key
*.pem
*.crt
*.p12
*.pfx
*.secret.json
.env.local
.env.production.local

# ── Claude Code 本地設定（settings.json 為專案共享 hooks 設定，需 commit）──
.claude/settings.local.json

# ── 編輯器 ──────────────────────────────────────────────────
.vscode/
.idea/
*.swp
*.swo
*~
Thumbs.db
.DS_Store

# wrangler files
.wrangler
.dev.vars*
!.dev.vars.example
