{
  "entries": [
    {
      "channel": "ntfy/wangsc2025",
      "time": "2026-03-07 11:14:51",
      "status": "success",
      "verse_text": "是日已過，命亦隨減，如少水魚，斯有何樂？大眾當勤精進，如救頭燃，但念無常，慎勿放逸。",
      "source": "《佛遺教經》（又名《佛垂般涅槃略說教誡經》）",
      "date": "2026-03-07",
      "author": "釋迦牟尼佛",
      "verse_id": 1
    },
    {
      "time": "2026-03-07 18:04:31",
      "verse_text": "若人靜坐一須臾，勝造恆沙七寶塔；寶塔畢竟化為塵，一念淨心成正覺。",
      "source": "《法華經》",
      "session": "evening",
      "status": "success",
      "author": "釋迦牟尼佛",
      "verse_id": 2,
      "date": "2026-03-07",
      "channel": "ntfy/wangsc2025"
    },
    {
      "session": "morning",
      "status": "success",
      "channel": "ntfy/wangsc2025",
      "date": "2026-03-08",
      "source": "《金剛般若波羅蜜經》",
      "author": "釋迦牟尼佛",
      "verse_text": "不應住色生心，不應住聲香味觸法生心，應無所住而生其心。",
      "verse_id": 3,
      "time": "2026-03-08 06:30:02"
    },
    {
      "session": "evening",
      "date": "2026-03-08",
      "source": "《金剛般若波羅蜜經》",
      "verse_text": "一切有為法，如夢幻泡影，如露亦如電，應作如是觀。",
      "time": "2026-03-08 17:05:01",
      "channel": "ntfy/wangsc2025",
      "author": "釋迦牟尼佛",
      "verse_id": 4,
      "status": "success"
    },
    {
      "date": "2026-03-09",
      "time": "2026-03-09 06:30:01",
      "status": "success",
      "channel": "ntfy/wangsc2025",
      "verse_text": "菩提本無樹，明鏡亦非臺，本來無一物，何處惹塵埃。",
      "author": "六祖惠能大師",
      "session": "morning",
      "verse_id": 5,
      "source": "《六祖大師法寶壇經》"
    },
    {
      "date": "2026-03-09",
      "verse_id": 6,
      "verse_text": "佛法在世間，不離世間覺；離世覓菩提，恰如求兔角。",
      "author": "六祖惠能大師",
      "session": "evening",
      "time": "2026-03-09 17:05:01",
      "source": "《六祖大師法寶壇經》",
      "channel": "ntfy/wangsc2025",
      "status": "success"
    },
    {
      "channel": "ntfy/wangsc2025",
      "time": "2026-03-10 06:30:01",
      "verse_text": "不經一番寒徹骨，焉得梅花撲鼻香。",
      "author": "黃蘗希運禪師",
      "session": "morning",
      "verse_id": 7,
      "status": "success",
      "source": "《黃蘗斷際禪師宛陵錄》",
      "date": "2026-03-10"
    },
    {
      "channel": "chatroom",
      "time": "2026-03-10 08:33:00",
      "verse_text": "一日不作，一日不食。",
      "author": "百丈懷海禪師",
      "session": "morning-chatroom",
      "verse_id": 8,
      "status": "success",
      "source": "百丈懷海禪師農禪家風",
      "date": "2026-03-10"
    },
    {
      "date": "2026-03-10",
      "source": "《大乘起信論》",
      "verse_id": 9,
      "channel": "ntfy/wangsc2025",
      "author": "馬鳴菩薩",
      "status": "success",
      "time": "2026-03-10 17:05:02",
      "session": "evening",
      "verse_text": "心生種種法生，心滅種種法滅。"
    },
    {
      "date": "2026-03-10",
      "source": "《大方廣圓覺修多羅了義經》",
      "verse_id": 10,
      "channel": "chatroom",
      "author": "釋迦牟尼佛",
      "status": "success",
      "time": "2026-03-10 17:34:00",
      "session": "evening-chatroom",
      "verse_text": "知幻即離，不作方便；離幻即覺，亦無漸次。"
    },
    {
      "verse_id": 11,
      "verse_text": "勿以善小而不為，勿以惡小而為之。",
      "source": "《大般涅槃經》（南本卷三十六）",
      "author": "釋迦牟尼佛",
      "session": "evening",
      "channel": "ntfy/wangsc2025",
      "date": "2026-03-11",
      "time": "2026-03-11 17:05:01",
      "status": "success"
    },
    {
      "verse_id": 12,
      "channel": "ntfy/wangsc2025",
      "source": "《楞嚴經》卷二",
      "date": "2026-03-12",
      "status": "success",
      "session": "evening",
      "time": "2026-03-12 17:05:01",
      "verse_text": "若能轉物，即同如來。",
      "author": "釋迦牟尼佛"
    },
    {
      "status": "success",
      "verse_id": 13,
      "date": "2026-03-13",
      "channel": "ntfy/wangsc2025",
      "session": "evening",
      "time": "2026-03-13 17:05:01",
      "author": "釋迦牟尼佛",
      "verse_text": "制心一處，無事不辦。",
      "source": "《佛遺教經》"
    },
    {
      "verse_text": "千里之行，始於足下；菩薩萬行，始於發心。",
      "verse_id": 14,
      "status": "success",
      "session": "evening",
      "author": "釋迦牟尼佛",
      "source": "《華嚴經・淨行品》意旨",
      "date": "2026-03-14",
      "channel": "ntfy/wangsc2025",
      "time": "2026-03-14 17:05:01"
    },
    {
      "verse_text": "不忘初心，方得始終。",
      "status": "success",
      "channel": "ntfy/wangsc2025",
      "date": "2026-03-15",
      "source": "《華嚴經》",
      "author": "釋迦牟尼佛",
      "verse_id": 15,
      "session": "evening",
      "time": "2026-03-15 17:05:01"
    },
    {
      "session": "evening",
      "verse_id": 16,
      "channel": "ntfy/wangsc2025",
      "date": "2026-03-16",
      "author": "神秀大師",
      "status": "success",
      "time": "2026-03-16 17:05:01",
      "verse_text": "身是菩提樹，心如明鏡臺，時時勤拂拭，勿使惹塵埃。",
      "source": "《六祖大師法寶壇經》"
    },
    {
      "time": "2026-03-17 06:30:01",
      "verse_text": "朝看花開滿樹紅，暮看花落樹還空；若將花比人間事，花與人間事一同。",
      "verse_id": 17,
      "author": "龍舒居士王日休",
      "source": "《龍舒淨土文》",
      "date": "2026-03-17",
      "status": "success",
      "session": "morning",
      "channel": "ntfy/wangsc2025"
    },
    {
      "date": "2026-03-17",
      "source": "《楞嚴經》卷五",
      "channel": "ntfy/wangsc2025",
      "author": "觀世音菩薩（佛陀轉述）",
      "verse_text": "從聞思修入三摩地。",
      "verse_id": 18,
      "time": "2026-03-17 17:05:01",
      "session": "evening",
      "status": "success"
    },
    {
      "verse_id": 19,
      "source": "《西齋淨土詩》",
      "channel": "ntfy/wangsc2025",
      "date": "2026-03-18",
      "author": "省庵大師",
      "verse_text": "人身難得今已得，佛法難聞今已聞；此身不向今生度，更待何生度此身。",
      "session": "morning",
      "status": "success",
      "time": "2026-03-18 06:30:02"
    },
    {
      "verse_id": 20,
      "date": "2026-03-18",
      "verse_text": "莫謂老來方學道，孤墳多是少年人。",
      "session": "evening",
      "author": "蕅益智旭大師",
      "channel": "ntfy/wangsc2025",
      "source": "《寒笳集》",
      "time": "2026-03-18 17:05:01",
      "status": "success"
    }
  ]
}