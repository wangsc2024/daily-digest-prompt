{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://github.com/wangsc2024/daily-digest-prompt/schemas/skill-registry.json",
  "title": "Skill Registry Schema",
  "description": "Machine-readable Skill Registry（ADR-033），由 tools/sync_skill_registry.py 自動產生",
  "type": "object",
  "required": ["version", "generated_at", "skills", "meta"],
  "properties": {
    "version": { "type": "integer", "description": "Schema 版本" },
    "generated_at": { "type": "string", "format": "date-time" },
    "skills": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["name", "path"],
        "properties": {
          "name": { "type": "string", "description": "Skill 名稱（唯一）" },
          "path": { "type": "string", "description": "SKILL.md 相對路徑" },
          "version": { "type": "string", "description": "Skill 版本號（semver）" },
          "description": { "type": "string" },
          "triggers": {
            "type": "array",
            "items": { "type": "string" },
            "description": "觸發關鍵字"
          },
          "depends_on": {
            "type": "array",
            "items": { "type": "string" },
            "description": "依賴的其他 Skills 或配置"
          },
          "allowed_tools": {
            "type": "array",
            "items": { "type": "string" }
          },
          "stability": {
            "type": "string",
            "enum": ["stable", "beta", "experimental", "deprecated"],
            "description": "穩定性等級"
          },
          "updated_at": { "type": "string", "description": "最後更新時間" },
          "source": {
            "type": "string",
            "description": "來源（project / global）"
          },
          "in_skill_index": { "type": "boolean", "description": "是否已列於 SKILL_INDEX.md" }
        }
      }
    },
    "meta": {
      "type": "object",
      "properties": {
        "total_skills": { "type": "integer" },
        "skills_in_index": { "type": "integer" },
        "skills_missing_from_index": { "type": "integer" },
        "trigger_conflicts": { "type": "integer" },
        "broken_dependencies": { "type": "integer" }
      }
    }
  },
  "_metadata": {
    "version": "1.0.0",
    "created_at": "2026-03-20",
    "adr": "ADR-20260320-033"
  }
}
