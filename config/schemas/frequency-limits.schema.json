{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://daily-digest-prompt/schemas/frequency-limits.schema.json",
  "title": "Auto Task Frequency Limits Configuration",
  "description": "自動任務頻率限制配置（無 Todoist 待辦時觸發）",
  "type": "object",
  "required": ["version", "tracking_file", "trigger_modes", "history_file", "reset_policy", "selection_strategy", "tasks"],
  "properties": {
    "version": {
      "type": "integer",
      "const": 4,
      "description": "配置版本號（目前為 4，2026-03-10 合併 model-selection.yaml）"
    },
    "tracking_file": {
      "type": "string",
      "pattern": "^context/.+\\.json$",
      "description": "追蹤檔案路徑"
    },
    "trigger_modes": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["name", "description"],
        "properties": {
          "name": {
            "type": "string",
            "enum": ["無可處理項目", "今日任務全部完成"],
            "description": "觸發模式名稱"
          },
          "description": {
            "type": "string",
            "minLength": 1
          },
          "note": {
            "type": "string",
            "description": "額外說明（可選）"
          }
        }
      },
      "minItems": 1,
      "maxItems": 2
    },
    "history_file": {
      "type": "string",
      "pattern": "^state/.+\\.json$",
      "description": "歷史記錄檔案路徑"
    },
    "reset_policy": {
      "type": "string",
      "enum": ["daily", "weekly", "monthly"],
      "description": "重置策略"
    },
    "selection_strategy": {
      "type": "string",
      "enum": ["round_robin", "priority", "random"],
      "description": "選取策略"
    },
    "default_model": {
      "type": "string",
      "description": "預設模型（空字串 = 使用 Claude Code 當前預設模型）"
    },
    "initial_schema": {
      "type": "string",
      "description": "初始檔案格式說明（可選，僅供參考）"
    },
    "max_auto_per_run": {
      "type": "object",
      "description": "每次觸發最多執行的自動任務數",
      "properties": {
        "single_mode": { "type": "integer", "minimum": 1 },
        "team_mode": { "type": "integer", "minimum": 1 }
      }
    },
    "history": {
      "type": "object",
      "description": "歷史追蹤設定"
    },
    "all_exhausted_action": {
      "type": "string",
      "description": "全部達上限時的動作（描述用）"
    },
    "all_exhausted_fallback": {
      "type": "string",
      "description": "達上限時先執行的排程（如 jiaoguang_podcast_one = 依專輯製作 1 集 podcast）"
    },
    "all_exhausted_notify_message": {
      "type": "string",
      "description": "執行 fallback 後 Phase 3 通知內容（如：今日自動任務已達上限故製作1集淨土教觀學苑podcast）"
    },
    "all_exhausted_fallback_primary": {
      "type": "string",
      "enum": ["claude", "cursor_cli"],
      "description": "排程優先模型：claude=腳本流程；cursor_cli=cursor-cli skill。備援規則：非 cursor_cli 則備援 cursor_cli；cursor_cli 則備援 claude"
    },
    "tasks": {
      "type": "object",
      "description": "自動任務定義",
      "patternProperties": {
        "^[a-z_]+$": {
          "$ref": "#/$defs/autoTask"
        }
      },
      "minProperties": 1
    }
  },
  "$defs": {
    "autoTask": {
      "type": "object",
      "required": ["name", "daily_limit", "counter_field", "template", "history_type", "execution_order"],
      "properties": {
        "name": {
          "type": "string",
          "minLength": 1,
          "description": "任務顯示名稱"
        },
        "daily_limit": {
          "type": "integer",
          "minimum": 0,
          "maximum": 20,
          "description": "每日執行次數上限（0=停用, 1-20=啟用）"
        },
        "counter_field": {
          "type": "string",
          "pattern": "^[a-z_]+_count$",
          "description": "計數器欄位名稱（需以 _count 結尾）"
        },
        "template": {
          "type": "string",
          "pattern": "^templates/auto-tasks/.+\\.md$",
          "description": "任務模板路徑"
        },
        "template_params": {
          "type": "object",
          "description": "模板參數（可選，鍵值對傳入模板）",
          "additionalProperties": true
        },
        "history_type": {
          "type": "string",
          "pattern": "^[a-z_]+$",
          "description": "歷史記錄類型標識"
        },
        "execution_order": {
          "type": "integer",
          "minimum": 1,
          "maximum": 50,
          "description": "輪轉排序依據（1-50）"
        },
        "skill": {
          "type": "string",
          "minLength": 1,
          "description": "關聯的 Skill 名稱（可選，單數形式）"
        },
        "skills": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          },
          "minItems": 1,
          "description": "關聯的 Skills 清單（可選，複數形式）"
        },
        "description": {
          "type": "string",
          "minLength": 1,
          "description": "任務詳細說明（可選）"
        },
        "stages": {
          "type": "object",
          "description": "多階段任務的階段定義（可選，key 為階段編號，value 為說明）",
          "additionalProperties": {
            "type": "string",
            "minLength": 1
          }
        },
        "template_version": {
          "type": "integer",
          "minimum": 1,
          "description": "模板版本號（G10：≥1 啟用 prompt_content 展開，可選）"
        },
        "model": {
          "type": "string",
          "description": "執行此任務的 Claude 模型（可選，如 claude-haiku-4-5、claude-sonnet-4-5）"
        }
      },
      "additionalProperties": false
    }
  }
}
