# L8: 新開發者參考 — 複製為 .env 並填入實際值
# 必要（跑 bot.js 的環境：意圖分類 / 簡答 / 工作流分解 使用 Groq；Worker 端 Codex 採登入方案）
GROQ_API_KEY=your_groq_api_key_here
# my-gun-relay 生產環境（Render）
GUN_RELAY_URL=https://gun-relay-bxdc.onrender.com/gun

# 選填
PORT=3001
API_SECRET_KEY=
# Groq 模型（意圖分類、簡答、工作流分解）
GROQ_MODEL=llama-3.1-8b-instant

# 單次定時任務：時區與最遠排程天數
TIMEZONE=Asia/Taipei
SCHEDULED_MAX_DAYS=7

# 測試隔離目錄 (僅測試時使用，勿在生產設定)
# WSC_BOT_DATA_DIR=data_test
# WSC_BOT_TASKS_DIR=tasks_md_test

# LINE 任務類型測試 (bot/test-line-task-types.mjs)
# RELAY_LINE_WEBHOOK_URL=https://gun-relay-bxdc.onrender.com/api/line-webhook
# LINE_CHANNEL_SECRET=   # 與 relay .env 一致
# LINE_TEST_USER_ID=     # 模擬 LINE userId，relay 推回用
# RELAY_API_SECRET=      # 選填，用於 GET /api/replies 驗證
