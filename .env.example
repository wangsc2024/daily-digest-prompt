# Daily Digest Prompt - 環境變數範本
# 複製此檔案為 .env 並填入實際值
# cp .env.example .env

# Todoist API Token（必要）
TODOIST_API_TOKEN=

# Gmail OAuth（選用，Gmail Agent 使用）
# 需先完成 OAuth2 授權流程，詳見 skills/gmail/SKILL.md
# GMAIL_CREDENTIALS_PATH=credentials.json
# GMAIL_TOKEN_PATH=token.json

# ntfy Topic（選用，預設 wangsc2025）
 NTFY_TOPIC=wangsc2025

# Knowledge Base API（選用，預設 localhost:3000）
 KB_API_BASE=http://localhost:3000

# Bot.js 聊天室 API 認證（選用）
# 與 bot/.env 的 API_SECRET_KEY 保持相同值
 BOT_API_SECRET=your_secret_here

# OpenRouter API Key（Phase 2 維護任務：git_push、chatroom_optimize、skill_audit）
# 取得：openrouter.ai/keys → 建立 Key（以 sk-or-v1- 開頭）
# 未設定時自動 fallback 至 claude_haiku
OPENROUTER_API_KEY=

# Codex CLI（Phase 2 研究任務：11 個任務，訂閱制免 API Key）
# 安裝：npm install -g @openai/codex
# 已安裝時自動路由；未安裝時 fallback 至 openrouter_research
