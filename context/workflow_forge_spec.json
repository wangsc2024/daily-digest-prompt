{
  "gap_type": "output_schema",
  "gap_description": "28 個自動任務（todoist-auto-*.md）結果 JSON 缺少統一 Schema，導致格式不一致風險",
  "priority": "P0",
  "impact_score": 40,
  "executable_score": 35,
  "signal_score": 20,
  "total_score": 95,
  "artifact": {
    "type": "output_schema",
    "path": "config/schemas/results-auto-task-schema.json",
    "format": "JSON Schema (Draft 7)",
    "description": "自動任務結果 JSON 的統一 Schema 定義，供 Phase 3 驗證與文件參考"
  },
  "required_fields": [
    "agent",
    "task_key",
    "status",
    "executed_at",
    "execution_time_seconds"
  ],
  "optional_fields": [
    "artifact",
    "kb_imported",
    "kb_note_ids",
    "integration_status",
    "message",
    "error"
  ],
  "field_specs": {
    "agent": {
      "type": "string",
      "pattern": "^todoist-auto-[a-z_]+$",
      "description": "Agent 識別碼，格式 todoist-auto-{task_key}",
      "examples": ["todoist-auto-workflow_forge", "todoist-auto-self_heal"]
    },
    "task_key": {
      "type": "string",
      "pattern": "^[a-z_]+$",
      "description": "任務鍵（對應 frequency-limits.yaml tasks 鍵）",
      "examples": ["workflow_forge", "self_heal", "ai_deep_research"]
    },
    "status": {
      "type": "string",
      "enum": ["success", "partial", "failed", "format_failed"],
      "description": "執行狀態：success（完全成功）、partial（部分完成）、failed（執行失敗）、format_failed（格式驗證失敗）"
    },
    "executed_at": {
      "type": "string",
      "format": "date-time",
      "description": "執行時間（ISO 8601 格式，Asia/Taipei）",
      "example": "2026-03-17T06:35:39+08:00"
    },
    "execution_time_seconds": {
      "type": "number",
      "minimum": 0,
      "description": "執行耗時（秒）",
      "example": 120.5
    },
    "artifact": {
      "type": "object",
      "description": "產出物資訊（若任務產出檔案或工作流）",
      "properties": {
        "path": {"type": "string", "description": "產出檔案路徑"},
        "type": {"type": "string", "enum": ["workflow_yaml", "output_schema", "validation_checklist", "report", "code"], "description": "產出類型"},
        "gap_addressed": {"type": "string", "description": "解決的缺口簡述"}
      },
      "required": ["path", "type"]
    },
    "kb_imported": {
      "type": "boolean",
      "description": "是否已匯入知識庫"
    },
    "kb_note_ids": {
      "type": "array",
      "items": {"type": "string"},
      "description": "匯入知識庫的 note ID 列表"
    },
    "integration_status": {
      "type": "string",
      "enum": ["integrated", "proposed", "failed"],
      "description": "整合狀態：integrated（已整合）、proposed（建議變更）、failed（整合失敗）"
    },
    "message": {
      "type": "string",
      "description": "執行訊息或錯誤原因"
    },
    "error": {
      "type": "object",
      "description": "錯誤詳情（僅 status=failed 時）",
      "properties": {
        "type": {"type": "string"},
        "message": {"type": "string"},
        "details": {"type": "string"}
      }
    }
  },
  "validation_rules": [
    "agent 欄位必須與 task_key 一致：todoist-auto-{task_key}",
    "status 必須為四種枚舉值之一",
    "executed_at 必須為 ISO 8601 格式",
    "若 status=failed，error 欄位必填",
    "若有 artifact，path 欄位必填"
  ],
  "integration_plan": {
    "step1": "寫入 config/schemas/results-auto-task-schema.json",
    "step2": "在 docs/ARCHITECTURE.md 或 config/README.md 新增說明",
    "step3": "將此 schema 登記至 context/workflow-forge-registry.json"
  },
  "example": {
    "agent": "todoist-auto-workflow_forge",
    "task_key": "workflow_forge",
    "status": "success",
    "executed_at": "2026-03-17T06:35:39+08:00",
    "execution_time_seconds": 120.5,
    "artifact": {
      "path": "config/schemas/results-auto-task-schema.json",
      "type": "output_schema",
      "gap_addressed": "28 個自動任務結果 JSON 格式不一致"
    },
    "integration_status": "integrated",
    "kb_imported": true,
    "kb_note_ids": ["abc123"]
  }
}
